# Copy to `.env.local` and adjust to point the SPA at the real backend.

# Use the in-browser mock backend (default). Set to "false" to call the API.
VITE_USE_MOCK=false

# Base URL for the Python API. Leave blank to use same-origin / the Vite
# dev proxy ("/api" -> http://localhost:8000, configured in vite.config.ts).
VITE_API_URL=http://localhost:8000
