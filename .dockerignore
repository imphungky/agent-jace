# Build context is the repo root (see compose.yaml). This trims it for BOTH the
# API image (Dockerfile) and the Nginx image (deploy/nginx.Dockerfile).
#
# NOTE: the Nginx image now BUILDS the React app from source (multi-stage, see
# deploy/nginx.Dockerfile), so the frontend SOURCE must stay in the context.
# Only regenerated/installed artifacts (node_modules, dist) are excluded.

# Version control
.git
.gitignore
.github/

# Python
__pycache__/
*.py[cod]
.venv/
*.egg-info/
build/
wheels/

# Frontend: keep the source (the Nginx build stage compiles it); exclude only
# what the build regenerates — installed deps and the build output itself.
frontend/node_modules/
frontend/dist/
frontend/.vite/

# Env files: the root .env holds the OPENROUTER_API_KEY — never bake a secret
# into an image. frontend/.env.production is non-secret Vite build config that
# the build stage inlines into dist, so it is intentionally NOT excluded.
/.env
/.env.*

# Editor / OS cruft
.vscode/
.idea/
.DS_Store
*.swp
*.log

# Docs not needed inside the image (keep README.md — the API Dockerfile COPYs it)
*.md
!README.md

# Docker / compose files themselves
Dockerfile
compose.yaml
.dockerignore
